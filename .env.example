# Admin login for the locked settings tab. CHANGE THESE.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional initial RTSP stream (also settable later in the admin UI).
# Axis cameras typically use: rtsp://<user>:<pass>@<ip>/axis-media/media.amp
RTSP_URL=

# Optional initial SMTP settings (also settable later in the admin UI).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
